@{
    ViewData["Title"] = "Contact Us";
}

<div class="container mt-5">
    <h2>Contact Us</h2>
    <p>If you have any questions or feedback, feel free to reach out to us. We’d love to hear from you!</p>

    <h4>Contact Information</h4>
    <ul>
        <li><strong>Email:</strong> support@linkbookstationery.com</li>
        <li><strong>Phone:</strong> +27 71 668 9191</li>
        <li>
            <strong>Address:</strong>Central University of Technology, Free State
            Private Bag X20539
            BLOEMFONTEIN
            9300
        </li>
    </ul>

    <h4>Or send us a message:</h4>
    <form>
        <div class="form-group mb-3">
            <label for="name">Name</label>
            <input type="text" class="form-control" id="name" placeholder="Your name">
        </div>
        <div class="form-group mb-3">
            <label for="email">Email</label>
            <input type="email" class="form-control" id="email" placeholder="Your email">
        </div>
        <div class="form-group mb-3">
            <label for="message">Message</label>
            <textarea class="form-control" id="message" rows="4" placeholder="Your message"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Send</button>
    </form>
</div>

