@model ASPNETCore_DB.Models.Consumer

@{
    ViewData["Title"] = "Edit Consumer";
}

<h1 class="mb-4 text-primary">Edit Consumer</h1>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="p-4 shadow rounded bg-light">
            <form asp-action="Edit" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="ConsumerId" />

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-bold"></label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ContactNumber" class="form-label fw-bold"></label>
                    <input asp-for="ContactNumber" class="form-control" />
                    <span asp-validation-for="ContactNumber" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-bold"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                @if (!string.IsNullOrEmpty(Model?.Photo))
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold">Current Photo</label><br />
                        <input type="hidden" value="@Model.Photo" id="PhotoName" name="PhotoName" />
                        <img src="@WebConstants.ImagePath@Model.Photo" width="120" class="img-thumbnail rounded" />
                    </div>
                }

                <div class="mb-4">
                    <label class="form-label fw-bold">Upload New Photo</label>
                    <input type="file" name="files" id="uploadBox" multiple class="form-control" />
                </div>

                <div class="d-flex gap-2">
                    <input type="submit" value="Save" class="btn btn-success rounded-pill px-4 shadow-sm" />
                    <a asp-action="Index" class="btn btn-secondary rounded-pill px-4 shadow-sm">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
